{% comment %}
  NP Hero — Full-width hero with NP portrait inset (left) and content (right)
  Layout: Option B  |  Colors: warm/light (Option A palette)
{% endcomment %}

<style>
  .np-hero {
    display: flex;
    align-items: stretch;
    min-height: {{ section.settings.section_height }}px;
    background-color: #f7f4ef;
    overflow: hidden;
    position: relative;
  }

  .np-hero__portrait {
    flex: 0 0 38%;
    background-color: #ddd5c8;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 36px 28px 56px;
    gap: 16px;
    position: relative;
  }

  .np-hero__portrait-frame {
    width: 100%;
    max-width: 220px;
    aspect-ratio: 3 / 4;
    border-radius: 12px;
    overflow: hidden;
    border: 4px solid #fff;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.13);
    flex-shrink: 0;
  }

  .np-hero__portrait-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .np-hero__credential {
    position: absolute;
    bottom: 16px;
    left: 16px;
    background: rgba(255, 255, 255, 0.92);
    border-radius: 6px;
    padding: 7px 12px;
    font-size: 12px;
    font-weight: 600;
    color: #5a4f45;
    letter-spacing: 0.02em;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .np-hero__credential svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  .np-hero__quote {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    width: 100%;
    max-width: 340px;
    padding-bottom: 16px;
  }

  .np-hero__quote-mark {
    font-size: 52px;
    line-height: 0.75;
    color: #8b5e3c;
    font-style: normal;
    flex-shrink: 0;
  }

  .np-hero__quote-text {
    font-size: 15px;
    font-style: italic;
    line-height: 1.65;
    color: #5a4f45;
    margin: 0;
    text-align: left;
  }

  .np-hero__content {
    flex: 1 1 0%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 56px 64px;
    max-width: 580px;
  }

  .np-hero__eyebrow {
    display: block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #8a7f72;
    margin-bottom: 14px;
  }

  .np-hero__title {
    font-size: clamp(28px, 3.5vw, 46px);
    font-weight: 700;
    line-height: 1.15;
    color: #2c2820;
    margin: 0 0 16px;
    white-space: pre-line;
  }

  .np-hero__subtitle {
    font-size: 17px;
    line-height: 1.65;
    color: #5a4f45;
    margin: 0 0 32px;
    max-width: 440px;
  }

  .np-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
  }

  .np-hero__btn-primary {
    display: inline-block;
    background: #8b5e3c;
    color: #fff;
    font-size: 15px;
    font-weight: 600;
    padding: 13px 26px;
    border-radius: 6px;
    border: 1.5px solid #8b5e3c;
    text-decoration: none;
    transition: background 0.2s ease;
  }

  .np-hero__btn-primary:hover {
    background: #7a5234;
    color: #fff;
  }

  .np-hero__btn-secondary {
    display: inline-block;
    background: transparent;
    color: #8b5e3c;
    font-size: 15px;
    font-weight: 600;
    padding: 13px 26px;
    border-radius: 6px;
    border: 1.5px solid #8b5e3c;
    text-decoration: none;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .np-hero__btn-secondary:hover {
    background: #8b5e3c;
    color: #fff;
  }

  @media screen and (max-width: 749px) {
    .np-hero {
      flex-direction: column;
      min-height: unset;
    }

    .np-hero__portrait {
      flex: 0 0 auto;
      width: 100%;
      padding: 28px 24px 60px;
    }

    .np-hero__portrait-frame {
      max-width: 160px;
    }

    .np-hero__content {
      padding: 28px 24px 36px;
      max-width: 100%;
    }

    .np-hero__title {
      font-size: 28px;
    }

    .np-hero__subtitle {
      font-size: 15px;
    }
  }

  @media screen and (min-width: 750px) and (max-width: 990px) {
    .np-hero__content {
      padding: 40px 40px;
    }

    .np-hero__title {
      font-size: 32px;
    }
  }
</style>

<div class="np-hero">

  <div class="np-hero__portrait">
    <div class="np-hero__portrait-frame">
      {%- if section.settings.np_image != blank -%}
        {{
          section.settings.np_image
          | image_url: width: 900
          | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            widths: '300, 500, 900',
            sizes: '(max-width: 749px) 160px, 220px',
            alt: 'Licensed Nurse Practitioner'
        }}
      {%- else -%}
        <img
          src="https://cdn.shopify.com/s/files/1/0821/2067/1447/files/bethany-sanders-portrait.png?v=1780190442"
          alt="Licensed Nurse Practitioner"
          loading="eager"
          fetchpriority="high"
          width="220"
          height="293"
        >
      {%- endif -%}
    </div>

    {%- if section.settings.portrait_quote != blank -%}
      <div class="np-hero__quote">
        <span class="np-hero__quote-mark">&ldquo;</span>
        <p class="np-hero__quote-text">{{ section.settings.portrait_quote }}</p>
      </div>
    {%- endif -%}

    {%- if section.settings.show_credential_badge -%}
      <div class="np-hero__credential">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/>
        </svg>
        Licensed Geriatric Nurse Practitioner
      </div>
    {%- endif -%}
  </div>

  <div class="np-hero__content">
    {%- if section.settings.eyebrow != blank -%}
      <span class="np-hero__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}

    {%- if section.settings.title != blank -%}
      <h1 class="np-hero__title">{{ section.settings.title }}</h1>
    {%- endif -%}

    {%- if section.settings.subtitle != blank -%}
      <p class="np-hero__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}

    <div class="np-hero__actions">
      {%- if section.settings.btn_primary_label != blank -%}
        <a
          href="{{ section.settings.btn_primary_url | default: routes.all_products_collection_url }}"
          class="np-hero__btn-primary"
        >
          {{ section.settings.btn_primary_label }}
        </a>
      {%- endif -%}

      {%- if section.settings.btn_secondary_label != blank -%}
        <a
          href="{{ section.settings.btn_secondary_url | default: '/pages/about' }}"
          class="np-hero__btn-secondary"
        >
          {{ section.settings.btn_secondary_label }}
        </a>
      {%- endif -%}
    </div>
  </div>

</div>

{% schema %}
{
  "name": "NP Hero",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Portrait"
    },
    {
      "type": "image_picker",
      "id": "np_image",
      "label": "Nurse practitioner photo"
    },
    {
      "type": "checkbox",
      "id": "show_credential_badge",
      "label": "Show credential badge",
      "default": true
    },
    {
      "type": "textarea",
      "id": "portrait_quote",
      "label": "Portrait quote",
      "default": "Most falls are preventable. The right equipment at home keeps your loved ones safe, independent, and where they belong."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Nurse practitioner curated"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Headline",
      "default": "Medical equipment,\nmade easy"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Every product hand-picked by our licensed NP — so you know it's the right one for you."
    },
    {
      "type": "header",
      "content": "Primary button"
    },
    {
      "type": "text",
      "id": "btn_primary_label",
      "label": "Label",
      "default": "Shop all equipment"
    },
    {
      "type": "url",
      "id": "btn_primary_url",
      "label": "URL"
    },
    {
      "type": "header",
      "content": "Secondary button"
    },
    {
      "type": "text",
      "id": "btn_secondary_label",
      "label": "Label",
      "default": "Meet our NP"
    },
    {
      "type": "url",
      "id": "btn_secondary_url",
      "label": "URL"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "section_height",
      "min": 400,
      "max": 800,
      "step": 20,
      "unit": "px",
      "label": "Minimum height (desktop)",
      "default": 460
    }
  ],
  "presets": [
    {
      "name": "NP Hero",
      "settings": {
        "eyebrow": "Nurse practitioner curated",
        "title": "Medical equipment,\nmade easy",
        "subtitle": "Every product hand-picked by our licensed NP — so you know it's the right fit, no guesswork required.",
        "btn_primary_label": "Shop all equipment",
        "btn_secondary_label": "Meet our NP",
        "show_credential_badge": true,
        "portrait_quote": "Most falls are preventable. The right equipment at home keeps your loved ones safe, independent, and where they belong.",
        "section_height": 480
      }
    }
  ]
}
{% endschema %}
